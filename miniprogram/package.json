{
  "name": "huifu-miniprogram",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:h5": "vite",
    "build:h5": "vite build && node -e \"const fs=require('fs');const p=require('path');const d='dist/static';fs.mkdirSync(d,{recursive:true});['tab-home.svg','tab-home-active.svg','tab-timeline.svg','tab-timeline-active.svg','tab-pkg.svg','tab-pkg-active.svg','tab-ai.svg','tab-ai-active.svg'].forEach(f=>{const s=p.join('static',f),t=p.join(d,f);if(fs.existsSync(s))fs.copyFileSync(s,t)})",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:mp-weixin": "uni build -p mp-weixin"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4020920240930001",
    "@dcloudio/uni-h5": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4020920240930001",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.0",
    "@dcloudio/uni-automator": "3.0.0-4020920240930001",
    "@dcloudio/uni-cli-shared": "3.0.0-4020920240930001",
    "@dcloudio/uni-stacktracey": "3.0.0-4020920240930001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4020920240930001",
    "vite": "^5.4.0"
  }
}
